# Frontend configuration (Vite exposes only VITE_*-prefixed vars to the client).
# Copy to `.env.local` for local overrides. Never put secrets here — anything VITE_*
# is bundled into the public JavaScript and is visible to end users.

# Base URL of the backend API. In dev, leave empty to use the Vite proxy (/api -> :8080).
VITE_API_BASE_URL=

# Default tenant slug sent as X-Tenant-ID when none is chosen on the login screen.
VITE_DEFAULT_TENANT=demo
