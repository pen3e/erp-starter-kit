# Copy to `.env` and adjust. docker-compose reads this automatically.
# Never commit a real .env — secrets belong in your secret manager.

# --- Database ---
DB_NAME=erp
DB_USERNAME=erp
DB_PASSWORD=erp
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend ---
SERVER_PORT=8080
# Base64-encoded HMAC secret, min 256 bits. Generate with:
#   openssl rand -base64 48
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQta2V5LTEyMzQ1Njc4OTA=
CORS_ORIGINS=http://localhost:5173

# --- Demo data (DEV ONLY — never true in production) ---
BOOTSTRAP_DEMO_DATA=true
BOOTSTRAP_TENANT_SLUG=demo
BOOTSTRAP_ADMIN_EMAIL=admin@demo.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2024
